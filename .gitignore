# !.env.example

# =============================================================================
# FRONTEND: React / Node.js / Vite
# =============================================================================

# Dependencies
node_modules/

# Production Build Output
dist/
dist-ssr/
build/
out/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing & Coverage
coverage/
.nyc_output

# Caches
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo
.vite/

# =============================================================================
# BACKEND: Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / Packaging
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / Coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers & Linters (MyPy, Ruff, etc.)
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter Notebooks
.ipynb_checkpoints

# Logs and Databases
*.log
*.sqlite3
*.db

# Ignore output
output/*
# But don't ignore the hidden .gitkeep file
!output/.gitkeep